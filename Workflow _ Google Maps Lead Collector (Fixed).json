    {
      "parameters": {
        "jsCode": "const newLeads = $('Split Leads').all();\nlet existingLeads = [];\n\ntry {\n  const nodeData = $('Get Existing Leads').all();\n  if (nodeData && Array.isArray(nodeData)) {\n    existingLeads = nodeData.filter(item => item && item.json);\n  }\n} catch (e) {\n  console.log(\"No existing leads found yet\");\n}\n\nconst existingWebsites = new Set();\nconst existingMapUrls = new Set();\n\nexistingLeads.forEach(lead => {\n  const website = lead.json['Website'] || '';\n  const mapUrl = lead.json['Google Maps URL'] || '';\n  if (website) existingWebsites.add(website.toString().toLowerCase().trim().replace(/\\/$/, ''));\n  if (mapUrl) existingMapUrls.add(mapUrl.toString().toLowerCase().trim().replace(/\\/$/, ''));\n});\n\nconst today = new Date().toISOString().split('T')[0];\nconst filtered = [];\n\nnewLeads.forEach(lead => {\n  const website = lead.json.websiteUri || '';\n  const mapUrl = lead.json.googleMapsUri || '';\n  \n  // FLEXIBLE NAME SEARCH: Try displayName, then fallback to 'Unknown Business'\n  const name = lead.json.displayName?.text || lead.json.name || \"Unknown Business\";\n  \n  const normWebsite = website.toString().toLowerCase().trim().replace(/\\/$/, '');\n  const normMapUrl = mapUrl.toString().toLowerCase().trim().replace(/\\/$/, '');\n\n  const websiteExists = normWebsite && existingWebsites.has(normWebsite);\n  const mapUrlExists = normMapUrl && existingMapUrls.has(normMapUrl);\n\n  if (!websiteExists && !mapUrlExists) {\n    filtered.push({\n      json: {\n        \"Date\": today,\n        \"Business Name\": name,\n        \"Category\": lead.json.types && lead.json.types.length > 0 ? lead.json.types[0] : '',\n        \"Address\": lead.json.formattedAddress || '',\n        \"City\": lead.json.City || '',\n        \"Country\": lead.json.Country || '',\n        \"Phone\": lead.json.internationalPhoneNumber || '',\n        \"Website\": website,\n        \"Rating\": lead.json.rating || '',\n        \"Reviews\": lead.json.userRatingCount || 0,\n        \"Google Maps URL\": mapUrl,\n        \"Status\": \"Pending Analysis\",\n        \"Public Email\": \"\",\n        \"Owner Name\": \"\",\n        \"Facebook\": \"\",\n        \"Instagram\": \"\",\n        \"LinkedIn\": \"\",\n        \"Business Summary\": \"\",\n        \"Website Score\": \"\",\n        \"Lead Score\": \"\"\n      }\n    });\n  }\n});\n\nreturn filtered;"
      },
