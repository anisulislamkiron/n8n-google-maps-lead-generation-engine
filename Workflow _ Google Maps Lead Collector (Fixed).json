    {
      "parameters": {
        "jsCode": "// 1. Create an empty master list to hold all leads from all pages\nlet allLeads = [];\nconst token = $json.nextPageToken || '';\n\n// 2. Loop through EVERY item (every page) coming from the API node\nfor (const item of $input.all()) {\n  const places = item.json.places;\n  \n  // If this page has leads, add them to our master list\n  if (places && Array.isArray(places)) {\n    allLeads = allLeads.concat(places);\n  }\n}\n\nif (allLeads.length === 0) {\n  return []; // Return nothing if no leads were found on any page\n}\n\n// 3. Turn the master list into individual n8n items\nreturn allLeads.map(place => {\n  return {\n    json: {\n      ...place,\n      nextPageToken: token\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
